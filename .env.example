# Copy this file to .env and adjust as needed.

# User/group ID the container runs as. Currently unused: docker-compose.yml
# hardcodes PUID/PGID to 0 (root) so Homepage can read /var/run/docker.sock
# directly for container status badges. Kept here in case that's reverted.
PUID=1000
PGID=1000

# Timezone used for date/time widgets and logs.
TZ=UTC

# Comma-separated list of "host:port" values Homepage will accept requests for.
# Required since Homepage v1.0. Add every hostname/IP:port you use to reach it.
HOMEPAGE_ALLOWED_HOSTS=localhost:3000

# Admin password for the Palworld server REST API (used by the Palworld widget).
PALWORLD_PASSWORD=senhaAdminAqui
